{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "Information about the user and their travel preferences.",
      "type": "object",
      "properties": {
        "username": { "type": "string", "description": "Unique explorer handle." },
        "displayName": { "type": "string", "description": "The user's full name." },
        "photoURL": { "type": "string", "description": "URL to the user's profile picture." },
        "bio": { "type": "string", "description": "A short bio about the explorer." },
        "achievements": { "type": "array", "items": { "type": "string" } },
        "stats": {
          "type": "object",
          "properties": {
            "totalLikes": { "type": "integer" },
            "totalTrips": { "type": "integer" },
            "daysExplored": { "type": "integer" }
          }
        },
        "vehicle": {
          "type": "object",
          "properties": {
            "make": { "type": "string" },
            "model": { "type": "string" },
            "drivetrain": { "type": "string" },
            "fuelType": { "type": "string" }
          }
        }
      },
      "required": ["username", "displayName"]
    },
    "FriendRequest": {
      "type": "object",
      "properties": {
        "fromId": { "type": "string" },
        "fromName": { "type": "string" },
        "toId": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "accepted", "rejected"] },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    },
    "Message": {
      "type": "object",
      "properties": {
        "senderId": { "type": "string" },
        "receiverId": { "type": "string" },
        "text": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    },
    "Itinerary": {
      "title": "Travel Itinerary",
      "description": "A planned journey through Namibia.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "userName": { "type": "string" },
        "userPhoto": { "type": "string" },
        "title": { "type": "string" },
        "overview": { "type": "string" },
        "days": { "type": "integer" },
        "month": { "type": "string" },
        "budget": { "type": "string" },
        "pace": { "type": "string" },
        "detailLevel": { "type": "string" },
        "data": { "type": "object", "description": "The full JSON output from Gemini." },
        "likes": { "type": "integer", "description": "Number of upvotes." },
        "isPublic": { "type": "boolean", "description": "Whether others can see this trip." },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "title", "data"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profiles."
    },
    "/usernames/{username}": {
      "schema": { "type": "object", "properties": { "uid": { "type": "string" } } },
      "description": "Unique username registry."
    },
    "/friendRequests/{requestId}": {
      "schema": "FriendRequest"
    },
    "/chats/{chatId}/messages/{messageId}": {
      "schema": "Message"
    },
    "/itineraries/{itineraryId}": {
      "schema": "Itinerary",
      "description": "Saved travel plans."
    },
    "/itineraries/{itineraryId}/likes/{userId}": {
      "schema": {
        "type": "object",
        "properties": {
          "likedAt": { "type": "string", "format": "date-time" }
        }
      },
      "description": "Subcollection to track unique likes."
    }
  }
}
